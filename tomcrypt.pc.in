pkg_dir=${pcfiledir}/../@PKG_DIR_BASENAME@
# tcl_pkg_path: directory a Tcl interpreter should add to auto_path
# for `package require @PACKAGE_NAME@` to resolve to this install.
tcl_pkg_path=${pkg_dir}

Name: @PACKAGE_NAME@
Description: Tcl bindings for libtomcrypt (hashing, HMAC, ciphers, AEAD, ECC, RSA)
Version: @PACKAGE_VERSION@
