-----END ENCRYPTED PRIVATE KEY-----
}

set passphrase correct-horse-battery-staple

test pem_decrypt-1.1 {decrypt an encrypted PKCS#8 RSA private key} -body { #<<<
	set key [tomcrypt::pem_decrypt $enc_rsa $passphrase]
	# Stringifies as plain PEM, ready to write out for postfix etc.
	string match "-----BEGIN RSA PRIVATE KEY-----\n*-----END RSA PRIVATE KEY-----\n" $key
} -cleanup {
	unset -nocomplain key
} -result 1
#>>>
test pem_decrypt-1.2 {decrypted RSA key is usable for sign/verify} -body { #<<<
	set key [tomcrypt::pem_decrypt $enc_rsa $passphrase]
	set pub [tomcrypt::rsa_extract_pubkey $key]
	set h   [tomcrypt::hash sha256 "hello world"]
	set sig [tomcrypt::rsa_sign_hash -key $key -hash $h]
	tomcrypt::rsa_verify_hash -key $pub -sig $sig -hash $h
} -cleanup {
	unset -nocomplain key pub h sig
} -result 1
#>>>
test pem_decrypt-1.3 {decrypt an encrypted PKCS#8 EC private key} -body { #<<<
	set key [tomcrypt::pem_decrypt $enc_ec $passphrase]
	string match "-----BEGIN EC PRIVATE KEY-----\n*-----END EC PRIVATE KEY-----\n" $key
} -cleanup {
	unset -nocomplain key
} -result 1
#>>>
test pem_decrypt-1.4 {decrypted EC key is usable for sign/verify} -body { #<<<
	set key [tomcrypt::pem_decrypt $enc_ec $passphrase]
	set pub [tomcrypt::ecc_extract_pubkey $key]
	set sig [tomcrypt::ecc_sign $key "hello world"]
	tomcrypt::ecc_verify $sig "hello world" $pub
} -cleanup {
	unset -nocomplain key pub sig
} -result 1
#>>>
test pem_decrypt-2.1 {wrong passphrase raises a clean error} -body { #<<<
	tomcrypt::pem_decrypt $enc_rsa wrong-password
} -returnCodes error -errorCode {TOMCRYPT PEM DECRYPT} \
  -match glob -result {pem_decode_pkcs failed: *}
#>>>
test pem_decrypt-2.2 {malformed PEM raises a clean error} -body { #<<<
	tomcrypt::pem_decrypt "not a pem at all" $passphrase
} -returnCodes error -errorCode {TOMCRYPT PEM DECRYPT} \
  -match glob -result {pem_decode_pkcs failed: *}
#>>>
test pem_decrypt-2.3 {wrong number of args} -body { #<<<
	tomcrypt::pem_decrypt $enc_rsa
} -returnCodes error -result {wrong # args: should be "tomcrypt::pem_decrypt encrypted_pem passphrase"}
#>>>

unset -nocomplain enc_rsa enc_ec passphrase

# cleanup
::tcltest::cleanupTests
return

